{
  "name": "@spaceagetv/macadam",
  "version": "2.1.1",
  "description": "Async node.js interface to Blackmagic Design capture and playback devices. Prebuilt fork of Streampunk/macadam.",
  "main": "index.js",
  "types": "index.d.ts",
  "keywords": [
    "blackmagic",
    "SDI",
    "playback",
    "capture",
    "decklink",
    "video",
    "sound"
  ],
  "files": [
    "index.js",
    "index.d.ts",
    "binding.gyp",
    "src",
    "decklink",
    "prebuilds"
  ],
  "scripts": {
    "install": "node-gyp-build",
    "build": "node-gyp rebuild",
    "prebuild": "prebuildify --napi --strip",
    "test": "tape test/*Spec.js",
    "lint": "eslint index.js **/*.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spaceagetv/macadam.git"
  },
  "author": "Streampunk Media Ltd",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/spaceagetv/macadam/issues"
  },
  "homepage": "https://github.com/spaceagetv/macadam#readme",
  "dependencies": {
    "highland": "^2.13.5",
    "node-gyp-build": "^4.8.4"
  },
  "gypfile": true,
  "devDependencies": {
    "eslint": "^8.10.0",
    "node-gyp": "^13.0.1",
    "prebuildify": "^6.0.1",
    "tape": "^5.5.2"
  }
}
